{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DbConn": "Server=YOUR_SERVER;Database=YOUR_DATABASE;User Id=YOUR_USERNAME;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;"
  },

  "FileStorageSettings": {
    "ImageSizeInMB": 30,
    "VideoSizeInMB": 50,
    "FileSizeInMB": 20,

    "UploadsFolder": "Uploads",
    "ImagesFolder": "Images",
    "VideosFolder": "Videos",
    "FilesFolder": "Files",

    "ImageExtensionAllowed": [
      ".jpg",
      ".png",
      ".jpeg"
    ],
    "FileExtensionAllowed": [
      ".pdf",
      ".pptx",
      ".docx"
    ],
    "VideoExtensionAllowed": [
      ".mp4",
      ".webm"
    ]
  },

  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "SenderName": "Elearning Platform",
    "SenderEmail": "your-email@example.com",
    "Username": "your-email@example.com",
    "Password": "YOUR_APP_PASSWORD"
  },

  "JwtSetting": {
    "SecretKey": "YOUR_SUPER_SECRET_JWT_KEY_HERE",
    "Issuer": "YourApi",
    "Audience": "YourClient",
    "DurationInMinutes": 200
  }
}